# Server
HOST=127.0.0.1
PORT=3000
NODE_ENV=production
MINIGAME_TZ=Asia/Shanghai
# Keep true for HTTPS. Set false only for temporary IP-over-HTTP testing.
SESSION_COOKIE_SECURE=true

# Admin
# IP deployment: set this to the public IP and visit /admin.
# Domain deployment: use a dedicated admin domain.
ADMIN_HOSTS=YOUR_SERVER_IP
ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_ROOT_ON_ADMIN_HOST=false

# Persistent data and uploaded media
MINIGAME_DATA_FILE=/var/lib/suyo-minigame/minigame.json
MINIGAME_UPLOAD_DIR=/var/lib/suyo-minigame/uploads
MAX_COVER_MB=12
MAX_VIDEO_MB=300
MAX_AVATAR_MB=6

# Email verification
# Examples: smtp.qq.com:465, smtp.163.com:465, smtp.feishu.cn:465
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sender@example.com
SMTP_PASS=replace-with-smtp-authorization-code
MAIL_FROM="溯造 MiniGame <sender@example.com>"
OTP_SECRET=replace-with-another-long-random-secret
OTP_TTL_MINUTES=10
OTP_RESEND_SECONDS=60
OTP_MAX_REQUESTS_PER_HOUR=5
OTP_MAX_REQUESTS_PER_IP_PER_HOUR=20
SESSION_TTL_DAYS=30

# Local development only. Never enable this in production.
ALLOW_DEV_OTP=false
