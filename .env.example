# Copy this file to /etc/suyo-minigame.env on the server.
# IP-only deployment:
#   frontend: http://YOUR_SERVER_IP/
#   admin:    http://YOUR_SERVER_IP/admin

HOST=127.0.0.1
PORT=3000
CHECKIN_TZ=Asia/Shanghai

# Replace this with your Aliyun public IP, for example 47.100.10.20.
# Use host/IP only, without http:// and without path.
ADMIN_HOSTS=YOUR_SERVER_IP

# Keep the admin password as requested.
ADMIN_PASSWORD=114514

# Important for IP-only deployment:
# "/" remains the participant check-in page, "/admin" is the admin page.
ADMIN_ROOT_ON_ADMIN_HOST=false

# Keep runtime data outside the git checkout so deploys do not overwrite it.
CHECKIN_DATA_FILE=/var/lib/suyo-minigame/checkins.json
CHECKIN_GEOFENCE_FILE=/opt/suyo-minigame/data/geofence-hbut.json
CHECKIN_COOLDOWN_MS=15000
