[Unit]
Description=SuYo MiniGame player voice service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=suyo
Group=suyo
WorkingDirectory=/opt/suyo-minigame
EnvironmentFile=/etc/suyo-minigame.env
ExecStart=/usr/bin/node /opt/suyo-minigame/server.js
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/suyo-minigame

[Install]
WantedBy=multi-user.target
