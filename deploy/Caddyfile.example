# Replace these with your real domains. Caddy gets HTTPS certificates automatically.

play.example.com, admin.example.com {
    encode zstd gzip
    request_body {
        max_size 2200MB
    }
    reverse_proxy 127.0.0.1:3000 {
        flush_interval -1
        transport http {
            read_timeout 60m
            write_timeout 60m
        }
    }
}
