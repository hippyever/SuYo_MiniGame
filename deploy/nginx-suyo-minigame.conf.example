# Replace checkin.example.com and admin.example.com with your real domains.
# After installing this file, run:
#   sudo certbot --nginx -d checkin.example.com -d admin.example.com

server {
    listen 80;
    listen [::]:80;
    server_name checkin.example.com admin.example.com;

    client_max_body_size 2m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
